services:
  app:
    build: .
    ports:
      - "{{APP_PORT}}:3000"
    volumes:
      - ./src:/app/src
    environment:
      - NODE_ENV=development
    restart: unless-stopped

  workspace:
    build:
      context: .
      dockerfile: Dockerfile.workspace
    volumes:
      - .:/workspace
    restart: unless-stopped
