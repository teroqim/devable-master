services:
  frontend:
    build: ./frontend
    ports:
      - "{{APP_PORT}}:3000"
    volumes:
      - ./frontend/src:/app/src
    environment:
      - NODE_ENV=development
      - NEXT_PUBLIC_API_URL=http://backend:3001
    depends_on:
      - backend
    restart: unless-stopped

  backend:
    build: ./backend
    ports:
      - "{{BACKEND_PORT}}:3001"
    volumes:
      - ./backend/src:/app/src
    environment:
      - NODE_ENV=development
      - DATABASE_URL=postgresql://app:{{DB_PASSWORD}}@postgres:5432/app
    depends_on:
      - postgres
    restart: unless-stopped

  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: app
      POSTGRES_USER: app
      POSTGRES_PASSWORD: {{DB_PASSWORD}}
    volumes:
      - ./.docker/pgdata:/var/lib/postgresql/data
    ports:
      - "{{DB_PORT}}:5432"

  workspace:
    build:
      context: .
      dockerfile: Dockerfile.workspace
    volumes:
      - .:/workspace
    restart: unless-stopped
