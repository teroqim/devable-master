{
  "name": "Full-stack",
  "description": "A combined Next.js frontend + Elysia API backend with PostgreSQL.",
  "runtime": "node",
  "needsDatabase": true,
  "hasFrontend": true,
  "internalPort": 3000,
  "directories": [
    "frontend/src/app",
    "frontend/src/components",
    "frontend/src/lib",
    "backend/src/routes",
    "backend/src/services",
    "backend/src/db",
    "backend/src/lib",
    "backend/prisma",
    ".docker",
    "shared/types"
  ],
  "files": [
    { "source": "docker-compose.yml.tmpl", "destination": "docker-compose.yml", "template": true },
    { "source": "Dockerfile.workspace.tmpl", "destination": "Dockerfile.workspace", "template": false },
    { "source": "frontend/Dockerfile.tmpl", "destination": "frontend/Dockerfile", "template": true },
    { "source": "frontend/package.json.tmpl", "destination": "frontend/package.json", "template": true },
    { "source": "frontend/tsconfig.json", "destination": "frontend/tsconfig.json", "template": false },
    { "source": "frontend/eslint.config.mjs", "destination": "frontend/eslint.config.mjs", "template": false },
    { "source": "frontend/.prettierrc.json", "destination": "frontend/.prettierrc.json", "template": false },
    { "source": "frontend/next.config.ts", "destination": "frontend/next.config.ts", "template": false },
    { "source": "frontend/src/app/layout.tsx.tmpl", "destination": "frontend/src/app/layout.tsx", "template": true },
    { "source": "frontend/src/app/page.tsx.tmpl", "destination": "frontend/src/app/page.tsx", "template": true },
    { "source": "frontend/src/app/globals.css", "destination": "frontend/src/app/globals.css", "template": false },
    { "source": "frontend/src/lib/api-client.ts.tmpl", "destination": "frontend/src/lib/api-client.ts", "template": true },
    { "source": "backend/Dockerfile.tmpl", "destination": "backend/Dockerfile", "template": true },
    { "source": "backend/package.json.tmpl", "destination": "backend/package.json", "template": true },
    { "source": "backend/tsconfig.json", "destination": "backend/tsconfig.json", "template": false },
    { "source": "backend/eslint.config.mjs", "destination": "backend/eslint.config.mjs", "template": false },
    { "source": "backend/.prettierrc.json", "destination": "backend/.prettierrc.json", "template": false },
    { "source": "backend/src/index.ts.tmpl", "destination": "backend/src/index.ts", "template": true },
    { "source": "backend/src/routes/health.ts", "destination": "backend/src/routes/health.ts", "template": false },
    { "source": "backend/prisma/schema.prisma.tmpl", "destination": "backend/prisma/schema.prisma", "template": true },
    { "source": "shared/types/index.ts", "destination": "shared/types/index.ts", "template": false },
    { "source": "CLAUDE.md.tmpl", "destination": "CLAUDE.md", "template": true },
    { "source": ".env.tmpl", "destination": ".env", "template": true }
  ]
}
